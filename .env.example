# Band live event source. Required.
# BAND_API_KEY is the Band Remote/External Agent API key shown once when the agent is created.
# BAND_ROOM_ID is the Band chat room UUID that contains that agent.
BAND_AUDIT_MODE=band
BAND_API_KEY=
BAND_ROOM_ID=
BAND_REST_URL=
BAND_VERIFY_ON_STARTUP=true
BAND_RECRUIT_LANE_PEERS=false
BAND_LANE_PEERS_JSON={}
BAND_CORS_ORIGINS=

# Model provider integrations.
# AI/ML API is the orchestration, extraction, compliance, and synthesis lane.
# Featherless is the independent red-team, model-risk, and fact-verification lane.
BAND_AGENT_MODE=live
BAND_AGENT_TIMEOUT_SECONDS=60
BAND_AGENT_MAX_TOKENS=1600
BAND_AGENT_TEMPERATURE=0.15
BAND_PROVIDER_MAX_ATTEMPTS=3
BAND_PACKET_IMPORT_MAX_MB=50
BAND_PACKET_IMPORT_MAX_TOKENS=5000
BAND_PACKET_IMPORT_TEMPERATURE=0
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=openai/gpt-4.1-mini-2025-04-14
AIML_CHAIR_MODEL=openai/gpt-4.1-2025-04-14
AIML_EVIDENCE_MODEL=
AIML_COMPLIANCE_MODEL=openai/gpt-4.1-2025-04-14
AIML_SYNTHESIZER_MODEL=openai/gpt-4.1-2025-04-14
AIML_PACKET_IMPORT_MODEL=
AIML_OCR_MODEL=mistral/mistral-ocr-latest
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
FEATHERLESS_SECURITY_MODEL=
FEATHERLESS_MODEL_RISK_MODEL=
FEATHERLESS_VERIFIER_MODEL=
# Faster Featherless fallback if 72B latency is too high:
# FEATHERLESS_MODEL=Qwen/Qwen2.5-32B-Instruct

# Frontend API target.
VITE_API_BASE_URL=http://127.0.0.1:8000
